# Namibia Sports Platform — Environment Variables
# Copy to .env and fill in values. Never commit .env to version control.

# ===== DATABASE =====
# Supabase PostgreSQL connection (use pooler port 6543 for serverless)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# ===== SUPABASE =====
SUPABASE_URL=https://rbibqjgsnrueubrvyqps.supabase.co
VITE_SUPABASE_URL=https://rbibqjgsnrueubrvyqps.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ===== AUTH (Manus OAuth / Custom) =====
JWT_SECRET=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=

# ===== AI =====
ANTHROPIC_API_KEY=

# ===== WHATSAPP =====
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# For Supabase Edge Function whatsapp-webhook (Meta verification)
WHATSAPP_VERIFY_TOKEN=sports-platform-verify

# ===== CLIENT (VITE_ prefix — exposed to browser) =====
VITE_SUPABASE_ANON_KEY=
VITE_TRPC_URL=/api/trpc

